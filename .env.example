# ============================================================
# 根级说明：每个 app 有自己的 .env，复制对应目录下的 .env.example
#   - apps/backend/.env
#   - apps/ai-service/.env
#   - apps/frontend/.env.local
# ============================================================

# ---- apps/backend/.env ----
# DATABASE_URL="file:./dev.db"
# AI_SERVICE_URL="http://localhost:8000"
# PORT=3001
# CORS_ORIGIN="http://localhost:3000"

# ---- apps/ai-service/.env ----
# 三家 provider，缺哪家启动都不报错，仅调用时报错；/health 返回已配置列表
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL="https://api.openai.com/v1"
# 分级路由默认模型（可覆盖）
# MODEL_SMALL="deepseek-chat"
# MODEL_MEDIUM="deepseek-chat"
# MODEL_LARGE="claude-sonnet-4-6"

# ---- apps/frontend/.env.local ----
# NEXT_PUBLIC_API_URL="http://localhost:3001/api"
