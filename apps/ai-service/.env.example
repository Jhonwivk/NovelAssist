# AI 服务环境变量 — 复制为 .env
# 三家 provider，缺哪家都不影响启动；/health 返回已配置列表。
# 调用对应 provider 时若未配置，会返回清晰错误。

# ---- 复用本地 Claude Code 配置（推荐：无需单独填 Key）----
# 直接把 ~/.claude/settings.json 的 env 块里这几项搬过来即可，
# 或运行仓库根目录脚本：python3 scripts/use-claude-code-config.py
# 智谱 BigModel / 其它 Anthropic 协议兼容端点都走这条通道。
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL="https://open.bigmodel.cn/api/anthropic"
ANTHROPIC_DEFAULT_MODEL="glm-5.2[1m]"
ANTHROPIC_API_KEY=

# ---- DeepSeek（OpenAI 兼容协议）----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# ---- OpenAI / 兼容端点 ----
OPENAI_API_KEY=
OPENAI_BASE_URL="https://api.openai.com/v1"

# ---- 分级路由：tier -> (provider, model) ----
# provider 在 anthropic | deepseek | openai 中选
PROVIDER_SMALL="anthropic"
MODEL_SMALL="glm-5.2[1m]"
PROVIDER_MEDIUM="anthropic"
MODEL_MEDIUM="glm-5.2[1m]"
PROVIDER_LARGE="anthropic"
MODEL_LARGE="glm-5.2[1m]"

# 跨域（前端直连时才需要；本架构前端走 NestJS，可留默认）
CORS_ORIGINS="http://localhost:3000"
